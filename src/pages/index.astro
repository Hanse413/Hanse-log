---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('log');

// Chronological order determines the running day count: DAY 001, 002, ...
const asc = [...entries].sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const dayNo = new Map(asc.map((e, i) => [e.id, i + 1]));

// Display newest first, grouped by month.
const desc = [...entries].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const monthKey = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });

const groups: { month: string; items: typeof desc }[] = [];
for (const e of desc) {
  const m = monthKey(e.data.date);
  const last = groups[groups.length - 1];
  if (last && last.month === m) last.items.push(e);
  else groups.push({ month: m, items: [e] });
}

const fmt = (d: Date) =>
  d.toISOString().slice(0, 10);
---

<Base>
  {groups.length === 0 && (
    <p>No entries yet. Add a markdown file to <code>src/content/log/</code> to write day one.</p>
  )}
  {groups.map((g) => (
    <section>
      <h2 class="month-label">{g.month}</h2>
      {g.items.map((e) => (
        <article class="entry-row">
          <span class="stamp">
            <span class="day">DAY {String(dayNo.get(e.id)).padStart(3, '0')}</span>
            {fmt(e.data.date)}
          </span>
          <h2><a href={`/log/${e.id}/`}>{e.data.title}</a></h2>
          {e.data.tags.length > 0 && (
            <p class="tags">{e.data.tags.map((t) => `#${t}`).join('  ')}</p>
          )}
        </article>
      ))}
    </section>
  ))}
</Base>
